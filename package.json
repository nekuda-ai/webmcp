{
  "name": "webmcp",
  "private": true,
  "type": "module",
  "scripts": {
    "directory:stats": "node scripts/webmcp-directory.mjs stats",
    "webmcp:probe": "node scripts/webmcp-playwright.mjs probe https://store.nekuda.ai",
    "webmcp:list": "node scripts/webmcp-playwright.mjs list https://store.nekuda.ai",
    "smoke": "node scripts/webmcp-directory.mjs search checkout --limit 3 && node scripts/webmcp-directory.mjs lookup https://store.nekuda.ai"
  },
  "devDependencies": {
    "playwright": "latest"
  }
}
